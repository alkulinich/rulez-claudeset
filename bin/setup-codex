#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
CODEX_DIR="${CODEX_DIR:-$HOME/.codex}"
SKILLS_DIR="$CODEX_DIR/skills"
SKILL_NAME="rulez-tools"
SKILL_SRC="$REPO_ROOT/adapters/codex/skills/$SKILL_NAME"
SKILL_DST="$SKILLS_DIR/$SKILL_NAME"
RULEZ_SRC="$REPO_ROOT/RULEZ.md"
AGENTS_APPEND_SRC="$REPO_ROOT/adapters/codex/AGENTS.append.md"
AGENTS_DST="$CODEX_DIR/AGENTS.md"
LEGACY_GENERATED_MARKER="<!-- generated by rulez-claudeset; do not edit directly -->"
MANAGED_BEGIN="<!-- rulez-claudeset:managed-begin -->"
MANAGED_END="<!-- rulez-claudeset:managed-end -->"

if [ ! -d "$SKILL_SRC" ]; then
  printf 'Error: missing Codex skill source: %s\n' "$SKILL_SRC" >&2
  exit 1
fi

if [ ! -f "$RULEZ_SRC" ]; then
  printf 'Error: missing shared guidance source: %s\n' "$RULEZ_SRC" >&2
  exit 1
fi

if [ ! -f "$AGENTS_APPEND_SRC" ]; then
  printf 'Error: missing Codex guidance appendix: %s\n' "$AGENTS_APPEND_SRC" >&2
  exit 1
fi

if [ ! -L "$SKILL_DST" ] && [ -e "$SKILL_DST" ]; then
  printf 'Error: Refusing to overwrite non-symlink: %s\n' "$SKILL_DST" >&2
  exit 1
fi

guidance_state="absent"
managed_begin_line=""
managed_end_line=""
if [ -e "$AGENTS_DST" ]; then
  managed_begin_count="$(grep -cFx "$MANAGED_BEGIN" "$AGENTS_DST" || true)"
  managed_end_count="$(grep -cFx "$MANAGED_END" "$AGENTS_DST" || true)"

  if [ "$managed_begin_count" -eq 0 ] && [ "$managed_end_count" -eq 0 ]; then
    if grep -qF "$LEGACY_GENERATED_MARKER" "$AGENTS_DST"; then
      guidance_state="legacy-generated"
    else
      guidance_state="manual"
    fi
  elif [ "$managed_begin_count" -eq 1 ] && [ "$managed_end_count" -eq 1 ]; then
    managed_begin_line="$(grep -nFx "$MANAGED_BEGIN" "$AGENTS_DST" | cut -d: -f1)"
    managed_end_line="$(grep -nFx "$MANAGED_END" "$AGENTS_DST" | cut -d: -f1)"
    if [ "$managed_begin_line" -lt "$managed_end_line" ]; then
      guidance_state="managed"
    else
      guidance_state="malformed"
    fi
  else
    guidance_state="malformed"
  fi
fi

if [ "$guidance_state" = "malformed" ]; then
  printf 'Error: malformed Rulez managed guidance markers: %s\n' "$AGENTS_DST" >&2
  exit 1
fi

render_managed_guidance() {
  printf '%s\n' "$MANAGED_BEGIN"
  cat "$RULEZ_SRC"
  printf '\n\n'
  cat "$AGENTS_APPEND_SRC"
  printf '\n%s\n' "$MANAGED_END"
}

mkdir -p "$SKILLS_DIR"

agents_tmp="$(mktemp "$CODEX_DIR/.AGENTS.md.rulez.XXXXXX")"
outside_tmp="$(mktemp "$CODEX_DIR/.AGENTS.md.outside.XXXXXX")"
cleanup() {
  rm -f "$agents_tmp" "$outside_tmp"
}
trap cleanup EXIT

case "$guidance_state" in
  manual)
    cat "$AGENTS_DST" > "$outside_tmp"
    ;;
  managed)
    if [ "$managed_begin_line" -gt 1 ]; then
      head -n "$((managed_begin_line - 1))" "$AGENTS_DST" >> "$outside_tmp"
    fi
    tail -n "+$((managed_end_line + 1))" "$AGENTS_DST" >> "$outside_tmp"
    ;;
esac

render_managed_guidance > "$agents_tmp"
cat "$outside_tmp" >> "$agents_tmp"

if [ -e "$AGENTS_DST" ]; then
  agents_mode="$(stat -f '%Lp' "$AGENTS_DST" 2>/dev/null \
    || stat -c '%a' "$AGENTS_DST" 2>/dev/null \
    || true)"
  if [ -n "$agents_mode" ]; then
    chmod "$agents_mode" "$agents_tmp"
  fi
fi

mv -f "$agents_tmp" "$AGENTS_DST"
agents_tmp=""

if [ -L "$SKILL_DST" ]; then
  rm "$SKILL_DST"
fi
ln -sfn "$SKILL_SRC" "$SKILL_DST"

printf 'Installed Codex skill: %s\n' "$SKILL_NAME"
printf '  %s -> %s\n' "$SKILL_DST" "$SKILL_SRC"
printf 'Updated Codex guidance block:\n'
printf '  %s\n' "$AGENTS_DST"
