#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
CODEX_DIR="${CODEX_DIR:-$HOME/.codex}"
SKILLS_DIR="$CODEX_DIR/skills"
SKILL_NAME="rulez-tools"
SKILL_SRC="$REPO_ROOT/adapters/codex/skills/$SKILL_NAME"
SKILL_DST="$SKILLS_DIR/$SKILL_NAME"
RULEZ_SRC="$REPO_ROOT/RULEZ.md"
AGENTS_APPEND_SRC="$REPO_ROOT/adapters/codex/AGENTS.append.md"
AGENTS_DST="$CODEX_DIR/AGENTS.md"
GENERATED_MARKER="<!-- generated by rulez-claudeset; do not edit directly -->"

if [ ! -d "$SKILL_SRC" ]; then
  printf 'Error: missing Codex skill source: %s\n' "$SKILL_SRC" >&2
  exit 1
fi

if [ ! -f "$RULEZ_SRC" ]; then
  printf 'Error: missing shared guidance source: %s\n' "$RULEZ_SRC" >&2
  exit 1
fi

if [ ! -f "$AGENTS_APPEND_SRC" ]; then
  printf 'Error: missing Codex guidance appendix: %s\n' "$AGENTS_APPEND_SRC" >&2
  exit 1
fi

mkdir -p "$SKILLS_DIR"

if [ -L "$SKILL_DST" ]; then
  rm "$SKILL_DST"
elif [ -e "$SKILL_DST" ]; then
  printf 'Error: Refusing to overwrite non-symlink: %s\n' "$SKILL_DST" >&2
  exit 1
fi

ln -sfn "$SKILL_SRC" "$SKILL_DST"

if [ -e "$AGENTS_DST" ] && ! grep -qF "$GENERATED_MARKER" "$AGENTS_DST"; then
  printf 'Error: Refusing to overwrite non-generated Codex guidance: %s\n' "$AGENTS_DST" >&2
  exit 1
fi

{
  printf '# AGENTS.md\n\n'
  printf '%s\n\n' "$GENERATED_MARKER"
  cat "$RULEZ_SRC"
  printf '\n\n'
  cat "$AGENTS_APPEND_SRC"
} > "$AGENTS_DST"

printf 'Installed Codex skill: %s\n' "$SKILL_NAME"
printf '  %s -> %s\n' "$SKILL_DST" "$SKILL_SRC"
printf 'Generated Codex guidance:\n'
printf '  %s\n' "$AGENTS_DST"
