#!/bin/bash
set -e

SKILL_DIR="$(cd "$(dirname "$0")/.." && pwd)"
CLAUDE_DIR="$HOME/.claude"
QUIET=false

[[ "$1" == "-q" ]] && QUIET=true

log() { $QUIET || echo "$@"; }

ask_replace() {
  # In quiet mode (auto-update), always skip
  $QUIET && return 1
  local what="$1"
  printf "%s already configured. Replace? [y/N] " "$what"
  read -r answer
  [[ "$answer" =~ ^[Yy]$ ]]
}

if ! command -v jq &>/dev/null; then
  echo "Error: jq is required (brew install jq)"
  exit 1
fi

# 1. Symlink commands
mkdir -p "$CLAUDE_DIR/commands"
ln -sfn "$SKILL_DIR/commands/rulez" "$CLAUDE_DIR/commands/rulez"
log "Linked commands → ~/.claude/commands/rulez"

# Symlink mctl into a user PATH location for shell use.
LOCAL_BIN="$HOME/.local/bin"
MCTL_LINK="$LOCAL_BIN/mctl"
MCTL_TARGET="$SKILL_DIR/scripts/mctl.sh"
mkdir -p "$LOCAL_BIN"
if [ -L "$MCTL_LINK" ]; then
  if [ "$(readlink "$MCTL_LINK")" = "$MCTL_TARGET" ]; then
    ln -sfn "$MCTL_TARGET" "$MCTL_LINK"
    log "Linked mctl -> ~/.local/bin/mctl"
  else
    echo "Warning: ~/.local/bin/mctl already exists and was not replaced"
  fi
elif [ -e "$MCTL_LINK" ]; then
  echo "Warning: ~/.local/bin/mctl already exists and was not replaced"
else
  ln -s "$MCTL_TARGET" "$MCTL_LINK"
  log "Linked mctl -> ~/.local/bin/mctl"
fi

case ":$PATH:" in
  *":$LOCAL_BIN:"*) ;;
  *) log "Warning: ~/.local/bin is not on PATH; add it or run scripts/mctl.sh directly" ;;
esac

for dep in tmux script fzf; do
  if ! command -v "$dep" >/dev/null 2>&1; then
    log "Warning: $dep is required for mctl"
  fi
done

# 2. Merge settings into ~/.claude/settings.json
SETTINGS_SRC="$SKILL_DIR/settings.json"
SETTINGS_DST="$CLAUDE_DIR/settings.json"

if [ ! -f "$SETTINGS_DST" ]; then
  cp "$SETTINGS_SRC" "$SETTINGS_DST"
  log "Installed ~/.claude/settings.json"
else
  # Always merge permissions (additive, deduplicated)
  merged="$(jq -s '
    .[0] as $existing | .[1] as $new |
    $existing * {
      permissions: {
        allow: (($existing.permissions.allow // []) + ($new.permissions.allow // []) | unique)
      }
    }
  ' "$SETTINGS_DST" "$SETTINGS_SRC")"

  # statusLine: skip if already set, ask in interactive mode
  has_statusline=$(echo "$merged" | jq -e '.statusLine' &>/dev/null && echo yes || echo no)
  if [ "$has_statusline" = "no" ]; then
    merged="$(echo "$merged" | jq --argjson sl "$(jq '.statusLine' "$SETTINGS_SRC")" '.statusLine = $sl')"
    log "Added statusLine"
  elif ask_replace "statusLine"; then
    merged="$(echo "$merged" | jq --argjson sl "$(jq '.statusLine' "$SETTINGS_SRC")" '.statusLine = $sl')"
    log "Replaced statusLine"
  else
    log "Kept existing statusLine"
  fi

  # SessionStart hook: skip if rulez-claudeset hook already present
  has_hook=$(echo "$merged" | jq -e '.hooks.SessionStart | map(select(.hooks[]?.command | test("rulez-claudeset"))) | length > 0' 2>/dev/null && echo yes || echo no)
  if [ "$has_hook" = "no" ]; then
    merged="$(echo "$merged" | jq '
      .hooks.SessionStart //= [] |
      .hooks.SessionStart += [{
        "matcher": "",
        "hooks": [{
          "type": "command",
          "command": "bash ~/.claude/skills/rulez-claudeset/bin/auto-update.sh &"
        }]
      }]
    ')"
    log "Added SessionStart auto-update hook"
  else
    log "SessionStart hook already present"
  fi

  # Stop hook: skip if rulez-claudeset hook already present.
  has_stop_hook=$(echo "$merged" | jq -e '.hooks.Stop | map(select(.hooks[]?.command | test("rulez-claudeset"))) | length > 0' 2>/dev/null && echo yes || echo no)
  if [ "$has_stop_hook" = "no" ]; then
    merged="$(echo "$merged" | jq '
      .hooks.Stop //= [] |
      .hooks.Stop += [{
        "matcher": "",
        "hooks": [{
          "type": "command",
          "command": "bash ~/.claude/skills/rulez-claudeset/scripts/punts-detect.sh"
        }]
      }]
    ')"
    log "Added Stop hook (punts detection)"
  else
    log "Stop hook already present"
  fi

  printf '%s\n' "$merged" > "$SETTINGS_DST"
  log "Merged ~/.claude/settings.json"
fi

# 3. Symlink RULEZ.md and add @RULEZ.md to CLAUDE.md
ln -sfn "$SKILL_DIR/RULEZ.md" "$CLAUDE_DIR/RULEZ.md"
log "Linked RULEZ.md → ~/.claude/RULEZ.md"

CLAUDE_MD="$CLAUDE_DIR/CLAUDE.md"
if [ ! -f "$CLAUDE_MD" ]; then
  echo "@RULEZ.md" > "$CLAUDE_MD"
  log "Created ~/.claude/CLAUDE.md with @RULEZ.md"
elif ! grep -qF '@RULEZ.md' "$CLAUDE_MD"; then
  echo "@RULEZ.md" >> "$CLAUDE_MD"
  log "Added @RULEZ.md to ~/.claude/CLAUDE.md"
else
  log "@RULEZ.md already in ~/.claude/CLAUDE.md"
fi

$QUIET || bash "$SKILL_DIR/scripts/check-deps.sh" || true

log "Done! Commands available as /rulez:start-issue, /rulez:create-pr, etc."
